#!/usr/bin/env bun
/**
 * pq-journal-log — append a journal record (or supersede/redact/compact).
 *
 * Usage:
 *   pq-journal-log <stream> '<json>'      streams: entries | saboteurs | commitments
 *   pq-journal-log <stream> --supersede <id>
 *   pq-journal-log <stream> --redact <id>      (expunged at compaction — honored absolutely)
 *   pq-journal-log <stream> --compact
 *
 * NON-INTERACTIVE — never prompts (skills call this mid-session; a prompt would
 * hang them). Validation, injection rejection, and HIGH-secret blocking happen
 * in validateLog; a rejected record exits 1 with a reason, nothing persisted.
 * Data lives in ~/.pq/journal/ (0600), local-only, no external sinks.
 */

import {
  journalPaths, ensureJournalDir, validateLog, makeRefEvent, appendEvent,
  rebuildSnapshot, compact, JOURNAL_STREAMS, type JournalStream, type JournalEvent,
} from "../lib/pq-journal";
import { flagValue } from "../lib/bin-context";

const args = process.argv.slice(2);
const stream = args[0] as JournalStream;

if (!stream || !JOURNAL_STREAMS.includes(stream)) {
  process.stderr.write(`pq-journal-log: first arg must be a stream: ${JOURNAL_STREAMS.join(" | ")}\n`);
  process.exit(1);
}

const rest = args.slice(1);
const paths = journalPaths(stream);
ensureJournalDir(paths);

if (rest.includes("--compact")) {
  const r = compact(paths);
  if (r.skipped) {
    console.log("compact skipped: concurrent write in progress; log left intact — re-run");
    process.exit(0);
  }
  console.log(`compacted: ${r.activeCount} active, ${r.archivedCount} archived, ${r.expungedCount} expunged`);
  process.exit(0);
}

const supersedeId = flagValue(rest, "--supersede");
const redactId = flagValue(rest, "--redact");
if (supersedeId || redactId) {
  const kind = supersedeId ? "supersede" : "redact";
  const targetId = (supersedeId || redactId) as string;
  appendEvent(paths, makeRefEvent(kind, targetId));
  rebuildSnapshot(paths);
  if (kind === "redact") {
    // Redact = "forget this". Compact immediately so the record leaves the
    // live log now, not at some future maintenance pass.
    compact(paths);
  }
  console.log(`${kind}: ${targetId}`);
  process.exit(0);
}

const jsonArg = rest.find((a) => !a.startsWith("--"));
if (!jsonArg) {
  process.stderr.write("pq-journal-log: provide a JSON record, or --supersede/--redact <id>, or --compact\n");
  process.exit(1);
}

let obj: Partial<JournalEvent>;
try {
  obj = JSON.parse(jsonArg);
} catch {
  process.stderr.write("pq-journal-log: invalid JSON\n");
  process.exit(1);
}

const res = validateLog(stream, obj);
if (!res.ok) {
  process.stderr.write(`pq-journal-log: ${res.error}\n`);
  process.exit(1);
}
appendEvent(paths, res.event);
rebuildSnapshot(paths);
console.log(res.event.id);
